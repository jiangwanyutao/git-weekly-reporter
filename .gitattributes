# 统一换行符：仓库内一律存 LF，检出时不再转 CRLF，保证 Windows/macOS 跨平台一致
* text=auto eol=lf

# Windows 专用脚本保留 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 二进制文件不做换行符处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.dll binary
*.exe binary
*.msi binary
*.dmg binary
